{
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "Bash(yarn *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(cd *)",
      "Bash(npx *)",
      "Bash(git stash *)",
      "Bash(git push *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(tsc *)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Write(**)",
      "Edit(**)",
      "Grep(**)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(rmdir /s*)",
      "Bash(del /f*)",
      "Bash(Remove-Item*-Recurse*)",
      "Bash(Remove-Item*-Force*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; echo \"$f\" | grep -qE '\\.dart$' && flutter analyze 2>/dev/null || true; } 2>/dev/null || true",
            "async": true,
            "statusMessage": "Running flutter analyze..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[\"[\", (now | todate), \"]\", (.tool_input.command // \"\")] | join(\" \")' >> ~/.claude/bash-log.txt 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Task complete.\"}'"
          }
        ]
      }
    ]
  }
}
