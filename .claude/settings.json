{
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write(*)",
      "Edit(*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(rmdir /s*)",
      "Bash(del /f*)",
      "Bash(Remove-Item*-Recurse*)",
      "Bash(Remove-Item*-Force*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; echo \"$f\" | grep -qE '\\.dart$' && flutter analyze 2>/dev/null || true; } 2>/dev/null || true",
            "async": true,
            "statusMessage": "Running flutter analyze..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[\"[\", (now | todate), \"]\", (.tool_input.command // \"\")] | join(\" \")' >> ~/.claude/bash-log.txt 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Task complete.\"}'"
          }
        ]
      }
    ]
  }
}
